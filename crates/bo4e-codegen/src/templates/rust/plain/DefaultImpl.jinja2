{%- if missing %}
// Default impl omitted: field `{{ missing | join("`, `") }}` has no default expression.
{%- else %}
impl Default for {{ class_name }} {
    fn default() -> Self {
        Self {
{%- for f in fields %}
            {{ f.name }}: {{ f.expr }},
{%- endfor %}
        }
    }
}
{%- endif %}
