[package]
name = "{{ crate_name }}"
version = "{{ semver }}"
edition = "2024"
description = "Generated Rust types for the BO4E energy data model, version {{ bo4e_version }}"
license = "Apache-2.0"

[dependencies]
serde = { version = "1", features = ["derive"] }
serde_json = "1"
chrono = { version = "0.4", features = ["serde"] }
uuid = { version = "1", features = ["serde", "v4", "macro-diagnostics"] }
rust_decimal = { version = "1", features = ["serde"] }
rust_decimal_macros = "1"
