{% for cls in classes -%}
from .{{ cls.module_path | join('.') }} import {{ cls.name }}
{% endfor -%}
{% for link in links -%}
from .many import {{ link }}
{% endfor -%}
from .__version__ import __version__

__all__ = [
    "__version__",
{%- for name in all_names | sort %}
    "{{ name }}",
{%- endfor %}
]

