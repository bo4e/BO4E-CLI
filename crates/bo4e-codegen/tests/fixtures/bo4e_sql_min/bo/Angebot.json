      "anyOf": [
        { "$ref": "../enum/Typ.json#" },
        { "type": "null" }
      ]
    },
    "adresse": {
      "default": null,
      "anyOf": [
        { "$ref": "../com/Adresse.json#" },
        { "type": "null" }
      ]
    },
    "adressen": {
      "type": "array",
      "items": { "$ref": "../com/Adresse.json#" }
    },
    "angebotsnummer": {
      "title": "Angebotsnummer",
      "default": null,
      "anyOf": [
        { "type": "string" },
        { "type": "null" }
      ]
    },
    "angebotsdatum": {
      "title": "Angebotsdatum",
      "default": null,
      "anyOf": [
